# Public web origin. Use HTTPS in production and do not include a trailing slash.
PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_COOKIE_SECURE=false

# Google Identity Services OAuth 2.0 Web client ID. The client ID is public;
# never place a Google client secret in the browser or this configuration.
GOOGLE_CLIENT_ID=

# Personal account storage (SQLite, single backend instance).
APP_DB_PATH=data/geoai_tko.sqlite3
ACCOUNT_BACKUP_DIR=backups/accounts
BACKUP_MAX_AGE_HOURS=36
# Set true in production after the scheduled backup is enabled.
BACKUP_HEALTH_REQUIRED=false
LOG_LEVEL=INFO

# Password and Google accounts must verify through the app email before cloud storage is enabled.
# Development writes email previews to data/account_mailbox and returns a test link.
# In production set this to false and configure SMTP below for real delivery.
ACCOUNT_DEV_EMAILS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=GeoAI TKO <no-reply@example.com>
SMTP_STARTTLS=true
