# Public web origin. Use HTTPS in production and do not include a trailing slash.
PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_COOKIE_SECURE=false
# Frontend build-time API timeout (milliseconds).
VITE_API_TIMEOUT_MS=30000

# Google Identity Services OAuth 2.0 Web client ID. The client ID is public;
# never place a Google client secret in the browser or this configuration.
GOOGLE_CLIENT_ID=

# Personal account storage (SQLite, single backend instance).
APP_DB_PATH=data/geoai_tko.sqlite3
ACCOUNT_BACKUP_DIR=backups/accounts
BACKUP_MAX_AGE_HOURS=36
# Set true in production after the scheduled backup is enabled.
BACKUP_HEALTH_REQUIRED=false
LOG_LEVEL=INFO

# Sentinel-2 mosaics and optional land-cover model assets.
MOSAICS_DIR=D:/data/mosaics
LULC_MODEL_PATH=D:/data/classifiers/lulc_classifier.pkl
LULC_MODEL_V2_PATH=D:/data/classifiers/lulc_classifier_v3.pkl
WORLDCOVER_PATH=D:/data/reference/esa_worldcover_turkestan.tif

# Request/resource controls. In a multi-instance deployment, enforce rate
# limits in a shared reverse proxy or Redis-backed service as well.
MAX_REQUEST_BYTES=2000000
MAX_ANALYSIS_PIXELS=2000000
MAX_GEOMETRY_VERTICES=10000
MAX_CONCURRENT_ANALYSES=2
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT=120
ANALYSIS_RATE_LIMIT=20
TILE_RATE_LIMIT=600
TILE_CACHE_SECONDS=86400

# Public Copernicus Data Space STAC scene discovery. This only returns scene
# metadata; annual-mosaic playback continues to use locally configured COGs.
CDSE_CATALOG_ENABLED=true
CDSE_CATALOG_TIMEOUT_SECONDS=12
CDSE_CATALOG_CACHE_SECONDS=300
MAX_CONCURRENT_CATALOG_SEARCHES=4

# Saved-zone threshold monitoring. Leave the scheduler disabled when multiple
# backend workers share SQLite; run one dedicated scheduler process instead.
MONITORING_SCHEDULER_ENABLED=false
MONITORING_INTERVAL_SECONDS=21600

# External narrative AI is optional; local deterministic fallbacks remain.
GROQ_API_KEY=
DEEPSEEK_API_KEY=
AI_TIMEOUT_SECONDS=15
AI_MAX_RETRIES=0

# Optional processing features.
ENABLE_DEMO_DATA=false
ENABLE_CHANGE_OVERVIEW=false
MAX_FORECAST_HORIZON_YEARS=5

# Password and Google accounts must verify through the app email before cloud storage is enabled.
# Development writes email previews to data/account_mailbox and returns a test link.
# In production set this to false and configure SMTP below for real delivery.
ACCOUNT_DEV_EMAILS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=GeoAI TKO <no-reply@example.com>
SMTP_STARTTLS=true
